#!/usr/bin/env python3
r"""{{ manifest.name }} MCP Server — generated by mcp-factory (FastMCP style).

{{ manifest.description | trim | docstring_safe }}

Generated: {{ generated_at }}
Runtime: {{ manifest.runtime.command | docstring_safe }}
Framework: fastmcp>=3.4.2 (pin the exact version you tested against in
           requirements.txt — this scaffold was validated against 3.4.2)
"""
from __future__ import annotations

import os
import sys
from typing import Annotated, Optional

from pydantic import Field
from fastmcp import FastMCP

SERVER_NAME = "{{ manifest.name }}"

# Presence-checked at startup by _check_required_env() — see that function's
# docstring for what this does and does not guarantee.
REQUIRED_ENV_VARS = [{% for e in manifest.env_required %}"{{ e }}"{% if not loop.last %}, {% endif %}{% endfor %}]

mcp = FastMCP(SERVER_NAME)


def _check_required_env() -> None:
    """Startup scoping gate for manifest.env_required.

    This is a presence check only: it confirms the env vars the manifest
    declared as required are set before the server starts serving tools, and
    warns (not fails) if any are missing so a misconfigured deployment is
    loud instead of silently returning bad data. It is NOT per-tool
    authorization or credential validation — it doesn't verify a key is
    valid, only that a value exists. Real auth boundaries (token
    verification, scope enforcement per tool) are a per-engagement build on
    top of this scaffold, same as the raw-SDK template.
    """
    missing = [name for name in REQUIRED_ENV_VARS if not os.environ.get(name)]
    if missing:
        print(
            f"[{SERVER_NAME}] WARNING: missing required env var(s): {', '.join(missing)}",
            file=sys.stderr,
        )

{% for tool in manifest.tools %}

@mcp.tool(name="{{ tool.name }}", description={{ tool.description | trim | py_str }})
async def {{ tool.name }}(
{% for arg in tool.args %}
{% set base_type = arg.type | pytype %}
{% set full_type = "Optional[" + base_type + "]" if not arg.required else base_type %}
    {{ arg.name }}: {% if arg.description %}Annotated[{{ full_type }}, Field(description={{ arg.description | py_str }})]{% else %}{{ full_type }}{% endif %}{% if not arg.required %} = None{% endif %},
{% endfor %}
) -> dict:
    try:
        # TODO: implement {{ tool.name }}
        return {"status": "not_implemented", "tool": "{{ tool.name }}"}
    except Exception as exc:  # fail-soft: a tool error must not crash the server
        return {"status": "error", "tool": "{{ tool.name }}", "error": str(exc)}
{% endfor %}


if __name__ == "__main__":
    _check_required_env()
    mcp.run()
