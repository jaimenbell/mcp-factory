#!/usr/bin/env node
// {{ manifest.name }} MCP Server — generated by mcp-factory.
//
// {{ manifest.description | trim | replace('\n', '\n// ') }}
//
// Generated: {{ generated_at }}
// Runtime: {{ manifest.runtime.command }}
"use strict";

const { McpServer } = require("@modelcontextprotocol/sdk/server/mcp.js");
const { StdioServerTransport } = require("@modelcontextprotocol/sdk/server/stdio.js");
const { z } = require("zod");

const server = new McpServer({
  name: "{{ manifest.name }}",
  version: "0.1.0",
});

{% for tool in manifest.tools %}
server.tool(
  "{{ tool.name }}",
  "{{ tool.description | replace('"', '\\"') | trim }}",
  {
{% for arg in tool.args %}
    {{ arg.name }}: z.{{ arg.type | replace('string', 'string()') | replace('number', 'number()') | replace('boolean', 'boolean()') | replace('object', 'object({})') | replace('array', 'array(z.unknown())') }}{% if not arg.required %}.optional(){% endif %},
{% endfor %}
  },
  async (args) => {
    // TODO: implement {{ tool.name }}
    return {
      content: [
        {
          type: "text",
          text: JSON.stringify({ status: "not_implemented", tool: "{{ tool.name }}" }),
        },
      ],
    };
  }
);

{% endfor %}
async function main() {
  const transport = new StdioServerTransport();
  await server.connect(transport);
}

main().catch((err) => {
  console.error("[{{ manifest.name }}] Fatal:", err);
  process.exit(1);
});
